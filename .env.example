# Public app URL used in password reset links.
# No trailing slash.
APP_BASE_URL=https://your-domain.example

# Brevo SMTP credentials for password reset emails.
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=your-brevo-login@smtp-brevo.com
BREVO_SMTP_PASSWORD=your_brevo_smtp_key_or_password

# Sender shown in the From field.
# The address must be verified in your Brevo account.
BREVO_FROM=noreply@your-domain.example
BREVO_FROM_NAME=AI Assistant

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/openclaw_admin
JWT_SECRET=change-me
ADMIN_EMAILS=admin@example.com
