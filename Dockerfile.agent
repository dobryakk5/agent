FROM node:22-slim

# Системные зависимости + Chromium для браузерного плагина
RUN apt-get update && apt-get install -y \
    bash \
    curl \
    git \
    chromium \
    chromium-driver \
    fonts-liberation \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libcups2 \
    libdbus-1-3 \
    libdrm2 \
    libgbm1 \
    libgtk-3-0 \
    libnspr4 \
    libnss3 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxkbcommon0 \
    libxrandr2 \
    xdg-utils \
    && rm -rf /var/lib/apt/lists/*

# Лучше фиксировать версию, а не тянуть latest
RUN npm install -g openclaw@2026.4.14

WORKDIR /workspace

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# Playwright/OpenClaw используют системный Chromium
ENV PLAYWRIGHT_BROWSERS_PATH=/usr/bin
ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
ENV CHROMIUM_FLAGS="--no-sandbox --disable-dev-shm-usage"

# Переменные по умолчанию
ENV ANTHROPIC_API_KEY=""
ENV OPENAI_API_KEY=""
ENV OPENROUTER_API_KEY=""
ENV TELEGRAM_BOT_TOKEN=""
ENV OPENCLAW_HEADLESS=true

# HTTP healthcheck по gateway
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
  CMD curl -sf http://127.0.0.1:18789/health >/dev/null || exit 1

ENTRYPOINT ["/entrypoint.sh"]